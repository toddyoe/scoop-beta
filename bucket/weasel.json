    "description": "Rime for Windows",
    "url": "https://github.com/rime/weasel/releases/download/latest/weasel-0.17.4.41.93eec2d-installer.exe#/dl.7z",
    "hash": "6360db702f6bb1e495386f985c7e1c2fa9bf713869eb77c619187d3fd46e2802",
    "pre_install": [
        "if(!(Test-Path \"$dir\\Rime\")) {New-Item \"$dir\\Rime\" -ItemType Directory | Out-Null} ",
        "& \"$dir\\WeaselSetup.exe\" /i",
        "& \"$dir\\WeaselDeployer.exe\" /install",
        "& \"$dir\\WeaselServer.exe\""
    ],
    "post_install": "Remove-Item \"$dir\\`$PLUGINSDIR\" -Recurse",
    "uninstaller": {
        "script": "Invoke-ExternalCommand \"$dir/uninstall.exe\" -ArgumentList '/S' -RunAs | Out-Null"
    },
    "checkver": {
        "url": "https://api.github.com/repos/rime/weasel/releases/tags/latest",
        "jsonpath": "$.assets[*].name",
        "regex": "weasel-([\\d.]+)\\.(?<commit>[a-f0-9]+)-installer\\.exe"
    },
    "autoupdate": {
        "url": "https://github.com/rime/weasel/releases/download/latest/weasel-$version.$matchCommit-installer.exe#/dl.7z"
    }
}
